        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/assignments/{id}": {
      "get": {
        "tags": ["Assignments"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Get assignment details",
        "responses": { "200": { "description": "Success" } }
      },
      "patch": {
        "tags": ["Assignments"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Update assignment",
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Assignments"],
        "security": [{ "bearerAuth": [] }],
