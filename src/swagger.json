{
  "openapi": "3.0.0",
  "info": {
    "title": "TalentFlow API",
    "version": "1.0.0",
    "description": "Comprehensive LMS Backend Documentation"
  },
  "servers": [
    {
      "url": "https://talentflow-backend-4dd1.onrender.com",
      "description": "Production Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register new user",
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "User login",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "User logout",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify email existence for reset",
        "responses": { "200": { "description": "Email verified" } }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Final Password Reset",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "newPassword": { "type": "string" }
                },
                "required": ["email", "newPassword"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Password updated" } }
      }
    },
    "/api/users/profile": {
      "get": {
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Get own profile",
        "responses": { "200": { "description": "Success" } }
      },
      "patch": {
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Update own profile",
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/api/users": {
      "get": {
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Get all users (Admin)",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/users/{id}": {
      "get": {
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Get user by ID (Admin)",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/users/{id}/role": {
      "patch": {
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Update user role (Admin)",
        "responses": { "200": { "description": "Role updated" } }
      }
    },
    "/api/users/{id}/progress": {
      "get": {
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Get specific user progress",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/courses": {
