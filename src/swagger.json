      "patch": {
        "tags": ["Courses"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Update course",
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Courses"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Delete course",
        "responses": { "204": { "description": "Deleted" } }
      }
    },
    "/api/courses/{id}/enroll": {
      "post": {
        "tags": ["Courses"],
