        "tags": ["Courses"],
        "summary": "List all courses",
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Courses"],
        "security": [{ "bearerAuth": [] }],
        "summary": "Create course (Instructor/Admin)",
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/courses/{id}": {
      "get": {
        "tags": ["Courses"],
        "summary": "Get course details",
        "responses": { "200": { "description": "Success" } }
